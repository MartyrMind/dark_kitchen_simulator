STREAM_SCAN_INTERVAL_MS=500
XREAD_BLOCK_MS=5000
XREAD_COUNT=10

MAX_DISPATCH_ATTEMPTS=5
DISPATCH_BACKOFF_BASE_MS=1000
DISPATCH_BACKOFF_MAX_MS=30000

HTTP_TIMEOUT_MS=3000
PROMETHEUS_PORT=9090
