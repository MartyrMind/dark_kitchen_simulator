SERVICE_NAME=kitchen-service
ENVIRONMENT=local
VERSION=0.1.0
LOG_LEVEL=INFO
LOG_FORMAT=readable

# Local example only. Put real credentials in .env, which is ignored by git.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kitchen_service
FULFILLMENT_SERVICE_URL=http://localhost:8003
HTTP_TIMEOUT_SECONDS=3
MONGO_URL=mongodb://localhost:27017
MONGO_DATABASE=dark_kitchen_events
MONGO_EVENTS_ENABLED=true
